{
    "name": "logistics-management-system",
    "description": "Comprehensive logistics and delivery management system",
    "type": "project",
    "require": {
        "php": ">=7.4",
        "firebase/php-jwt": "^6.0",
        "phpmailer/phpmailer": "^6.6",
        "twilio/sdk": "^7.0",
        "tecnickcom/tcpdf": "^6.4",
        "picqer/php-barcode-generator": "^2.2",
        "endroid/qr-code": "^4.4",
        "phpoffice/phpspreadsheet": "^1.24"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.5"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    }
}